# Database — SQLite for development
DATABASE_URL="file:./dev.db"

# JWT Secrets (change in production!)
JWT_ACCESS_SECRET="scs-access-secret-change-in-production-2026"
JWT_REFRESH_SECRET="scs-refresh-secret-change-in-production-2026"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5174

# ─── Email (SMTP) — Notification Emails ──────────────────────────
# In development (NODE_ENV=development), emails are printed to the console.
# To send real emails, set NODE_ENV=production and fill these in:
#
# Gmail Setup:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (enable it)
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Generate an App Password for "Mail"
#   4. Paste it below as SMTP_PASS
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# OTP
OTP_EXPIRY_MINUTES=10

# Account Lockout
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
