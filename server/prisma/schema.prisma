// This is your Prisma schema file for the Smart Campus System
// Module 1: Authentication & User Management
// Module 2: Digital ID & Profile
// Module 3: QR-Based Attendance
// Using SQLite for development, swap to PostgreSQL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  fullName          String    @map("full_name")
  passwordHash      String    @map("password_hash")
  role              String    // 'student' | 'faculty' | 'admin'
  isVerified        Boolean   @default(false) @map("is_verified")
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  otpTokens           OtpToken[]
  refreshTokens       RefreshToken[]
  profile             Profile?
  facultySessions     AttendanceSession[]  @relation("FacultySessions")
  attendanceRecords   AttendanceRecord[]   @relation("StudentAttendance")
  notices             Notice[]             @relation("AuthorNotices")
  subjectMarks        SubjectMark[]        @relation("StudentMarks")
  feePayments         FeePayment[]         @relation("StudentFees")
  calendarEvents      AcademicEvent[]      @relation("EventCreator")
  classroomMemberships ClassroomMember[]     @relation("ClassroomMembers")
  uploadedNotes       ClassNote[]           @relation("NoteUploader")
  sentMessages        ClassMessage[]        @relation("MessageSender")
  bookIssues          BookIssue[]           @relation("StudentBookIssues")
  librarianIssues     BookIssue[]           @relation("LibrarianBookIssues")
  // Hostel relations
  roomAllocations     RoomAllocation[]      @relation("StudentRoomAllocations")
  gatePasses          GatePass[]            @relation("StudentGatePasses")
  approvedGatePasses  GatePass[]            @relation("WardensApprovedPasses")
  hostelComplaints    HostelComplaint[]     @relation("StudentComplaints")
  resolvedComplaints  HostelComplaint[]     @relation("WardenResolvedComplaints")
  hostelFees          HostelFee[]           @relation("StudentHostelFees")
  // Events relations
  authoredEvents      Event[]               @relation("EventAuthor")
  uploadedEventFiles  EventFile[]           @relation("EventFileUploader")
  // Lost & Found
  lostFoundItems      LostFoundItem[]       @relation("LostFoundReporter")
  // Map Pins
  mapPins             MapPin[]              @relation("MapPinCreator")
  // Fee receipt approvals
  approvedFeeReceipts FeePayment[]          @relation("FeeApprover")
  // Assignments
  createdAssignments  Assignment[]          @relation("AssignmentCreator")
  assignmentSubmissions AssignmentSubmission[] @relation("SubmissionStudent")
  // Chat
  chatParticipants    ChatParticipant[]     @relation("UserChatParticipant")
  sentChatMessages    ChatMessage[]         @relation("ChatMsgSender")
  blockedUsers        BlockedUser[]         @relation("Blocker")
  blockedByUsers      BlockedUser[]         @relation("BlockedTarget")

  @@map("users")
}

model Profile {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  avatarBase64 String?  @map("avatar_base64")
  phone        String?
  bio          String?
  department   String?
  rollNumber   String?  @map("roll_number")
  year         Int?
  section      String?
  course       String?
  bloodGroup   String?  @map("blood_group")
  altPhone     String?  @map("alt_phone")
  universityRollNo String? @map("university_roll_no")
  university   String?
  hostelName   String?  @map("hostel_name")
  hostelRoom   String?  @map("hostel_room")
  homeAddress  String?  @map("home_address")
  employeeId   String?  @map("employee_id")
  designation  String?
  adminCode    String?  @map("admin_code")
  isLibrarian  Boolean  @default(false) @map("is_librarian")  // library faculty flag
  isWarden     Boolean  @default(false) @map("is_warden")     // hostel warden flag
  wardenBlock  String?  @map("warden_block")                 // block name they manage
  idCardNumber String   @unique @map("id_card_number")
  issuedAt     DateTime @default(now()) @map("issued_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model OtpToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  type      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("otp_tokens")
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  token       String   @unique
  expiresAt   DateTime @map("expires_at")
  revoked     Boolean  @default(false)
  userAgent   String?  @map("user_agent")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Module 3: Attendance ────────────────────────────────────────

model AttendanceSession {
  id           String   @id @default(uuid())
  facultyId    String   @map("faculty_id")
  subject      String
  sessionCode  String   @unique @map("session_code")
  date         DateTime
  duration     Int      @default(15)
  expiresAt    DateTime @map("expires_at")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  faculty      User               @relation("FacultySessions", fields: [facultyId], references: [id])
  records      AttendanceRecord[]

  @@index([facultyId])
  @@index([sessionCode])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  studentId   String   @map("student_id")
  markedAt    DateTime @default(now()) @map("marked_at")

  session     AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student     User              @relation("StudentAttendance", fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@map("attendance_records")
}

// ─── Module 4: Notices ───────────────────────────────────────────

model Notice {
  id             String   @id @default(uuid())
  title          String
  content        String
  category       String   @default("general")
  pdfBase64      String?  @map("pdf_base64")
  pdfFileName    String?  @map("pdf_file_name")
  staticPdfPath  String?  @map("static_pdf_path")  // filename in server/notices/ served statically
  authorId       String   @map("author_id")
  isPublished    Boolean  @default(true) @map("is_published")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  author         User     @relation("AuthorNotices", fields: [authorId], references: [id])

  @@index([authorId])
  @@index([createdAt])
  @@map("notices")
}

// ─── Module 5: Academics ─────────────────────────────────────

model Subject {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  semester     Int
  department   String
  credits      Int      @default(4)
  maxInternal  Int      @default(40) @map("max_internal")
  maxExternal  Int      @default(60) @map("max_external")
  createdAt    DateTime @default(now()) @map("created_at")

  marks        SubjectMark[]

  @@index([semester, department])
  @@map("subjects")
}

model SubjectMark {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  subjectId   String   @map("subject_id")
  internal    Float    @default(0)
  external    Float    @default(0)
  total       Float    @default(0)
  grade       String   @default("")
  result      String   @default("pending")  // pass | fail | pending
  semester    Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  student     User     @relation("StudentMarks", fields: [studentId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@index([studentId, semester])
  @@map("subject_marks")
}

model FeeStructure {
  id          String   @id @default(uuid())
  semester    Int
  year        Int
  course      String
  category    String   // tuition | hostel | exam | lab | library | transport
  amount      Float
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime @default(now()) @map("created_at")

  payments    FeePayment[]

  @@index([semester, course])
  @@map("fee_structures")
}

model FeePayment {
  id              String       @id @default(uuid())
  studentId       String       @map("student_id")
  feeStructureId  String       @map("fee_structure_id")
  amountPaid      Float        @map("amount_paid")
  status          String       @default("pending")  // paid | pending | overdue
  paidAt          DateTime?    @map("paid_at")
  transactionRef  String?      @map("transaction_ref")
  remarks         String?
  // Receipt upload
  receiptBase64   String?      @map("receipt_base64")
  receiptFileName String?      @map("receipt_file_name")
  receiptStatus   String       @default("none")  @map("receipt_status") // none | pending | approved | rejected
  approvedById    String?      @map("approved_by_id")
  approvedAt      DateTime?    @map("receipt_approved_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  student         User         @relation("StudentFees", fields: [studentId], references: [id])
  feeStructure    FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  approvedBy      User?        @relation("FeeApprover", fields: [approvedById], references: [id])

  @@unique([studentId, feeStructureId])
  @@index([studentId])
  @@map("fee_payments")
}

model AcademicEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime? @map("end_date")
  category    String   @default("general")  // exam | holiday | deadline | event | general
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  creator     User     @relation("EventCreator", fields: [createdBy], references: [id])

  @@index([date])
  @@map("academic_events")
}

// ─── Module: Classroom ───────────────────────────────────────

model Classroom {
  id          String   @id @default(uuid())
  name        String   @unique // e.g. "CS41"
  course      String             // e.g. "CS"
  section     String             // e.g. "41"
  createdAt   DateTime @default(now()) @map("created_at")

  members       ClassroomMember[]
  notes         ClassNote[]
  messages      ClassMessage[]
  assignments   Assignment[]

  @@map("classrooms")
}

model ClassroomMember {
  id          String   @id @default(uuid())
  classroomId String   @map("classroom_id")
  userId      String   @map("user_id")
  role        String   // "student" | "faculty"
  joinedAt    DateTime @default(now()) @map("joined_at")

  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user        User      @relation("ClassroomMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classroomId, userId])
  @@index([classroomId])
  @@index([userId])
  @@map("classroom_members")
}

model ClassNote {
  id          String   @id @default(uuid())
  classroomId String   @map("classroom_id")
  uploaderId  String   @map("uploader_id")
  title       String
  description String?
  fileName    String   @map("file_name")
  fileBase64  String   @map("file_base64")
  fileType    String   @map("file_type") // pdf, image, doc, ppt etc
  createdAt   DateTime @default(now()) @map("created_at")

  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  uploader    User      @relation("NoteUploader", fields: [uploaderId], references: [id])

  @@index([classroomId])
  @@map("class_notes")
}

model ClassMessage {
  id          String   @id @default(uuid())
  classroomId String   @map("classroom_id")
  senderId    String   @map("sender_id")
  content     String
  createdAt   DateTime @default(now()) @map("created_at")

  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  sender      User      @relation("MessageSender", fields: [senderId], references: [id])

  @@index([classroomId])
  @@map("class_messages")
}

// ─── Timetable (per section, admin-managed) ──────────────────

model Timetable {
  id          String   @id @default(uuid())
  section     String   @unique // e.g. "CS41"
  imageBase64 String   @map("image_base64")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("timetables")
}

// ─── Module: Library ─────────────────────────────────────────

model Book {
  id              String   @id @default(uuid())
  title           String
  author          String
  isbn            String   @unique
  category        String   @default("general")  // general | academic | reference | novel | journal | magazine
  publisher       String?
  publishYear     Int?     @map("publish_year")
  description     String?
  totalCopies     Int      @default(1) @map("total_copies")
  availableCopies Int      @default(1) @map("available_copies")
  shelfLocation   String?  @map("shelf_location")  // e.g. "A-12"
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  issues          BookIssue[]

  @@index([category])
  @@map("books")
}

model BookIssue {
  id            String    @id @default(uuid())
  bookId        String    @map("book_id")
  studentId     String    @map("student_id")
  issuedById    String    @map("issued_by_id")  // librarian or admin who issued
  issueDate     DateTime  @default(now()) @map("issue_date")
  dueDate       DateTime  @map("due_date")
  returnDate    DateTime? @map("return_date")
  status        String    @default("issued")  // issued | returned | overdue
  penaltyAmount Float     @default(0) @map("penalty_amount")  // Rs per day, computed on return
  penaltyPaid   Boolean   @default(false) @map("penalty_paid")
  penaltyRate   Float     @default(2) @map("penalty_rate")  // Rs per day after due date
  remarks       String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  book          Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  student       User      @relation("StudentBookIssues", fields: [studentId], references: [id])
  issuedBy      User      @relation("LibrarianBookIssues", fields: [issuedById], references: [id])

  @@index([studentId])
  @@index([bookId])
  @@index([status])
  @@map("book_issues")
}
// ─── Module: Hostel Management ───────────────────────────────

model HostelBlock {
  id          String       @id @default(uuid())
  name        String       @unique   // e.g. "Block A", "Girls Hostel 1"
  type        String       @default("boys")  // boys | girls | mixed
  totalFloors Int          @default(4) @map("total_floors")
  address     String?      // full address / location on campus
  wardenName  String?      @map("warden_name")
  wardenPhone String?      @map("warden_phone")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")

  rooms       HostelRoom[]
  complaints  HostelComplaint[]

  @@map("hostel_blocks")
}

model HostelRoom {
  id          String   @id @default(uuid())
  roomNumber  String   @map("room_number")   // e.g. "A-101"
  blockId     String   @map("block_id")
  floor       Int      @default(1)
  capacity    Int      @default(2)    // max occupants
  type        String   @default("double")  // single | double | triple | dormitory
  amenities   String   @default("")   // comma-separated: AC,WiFi,Attached Bathroom
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")

  block       HostelBlock      @relation(fields: [blockId], references: [id])
  allocations RoomAllocation[]
  complaints  HostelComplaint[]

  @@unique([roomNumber, blockId])
  @@index([blockId])
  @@map("hostel_rooms")
}

model RoomAllocation {
  id           String    @id @default(uuid())
  studentId    String    @map("student_id")
  roomId       String    @map("room_id")
  checkInDate  DateTime  @default(now()) @map("check_in_date")
  checkOutDate DateTime? @map("check_out_date")
  status       String    @default("active")  // active | vacated | transferred
  academicYear String    @map("academic_year")  // e.g. "2025-26"
  remarks      String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  student      User       @relation("StudentRoomAllocations", fields: [studentId], references: [id])
  room         HostelRoom @relation(fields: [roomId], references: [id])

  @@index([studentId])
  @@index([roomId])
  @@map("room_allocations")
}

model GatePass {
  id             String    @id @default(uuid())
  studentId      String    @map("student_id")
  purpose        String
  destination    String
  outDateTime    DateTime  @map("out_date_time")
  expectedReturn DateTime  @map("expected_return")
  actualReturn   DateTime? @map("actual_return")
  status         String    @default("pending")  // pending | approved | rejected | returned
  remarks        String?   // warden remarks on approval/rejection
  studentRemarks String?   @map("student_remarks")  // reason from student
  approvedById   String?   @map("approved_by_id")
  approvedAt     DateTime? @map("approved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  student      User   @relation("StudentGatePasses", fields: [studentId], references: [id])
  approvedBy   User?  @relation("WardensApprovedPasses", fields: [approvedById], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("gate_passes")
}

model MessMenu {
  id          String   @id @default(uuid())
  blockId     String?  @map("block_id")  // null = common for all blocks
  day         String   // Monday | Tuesday | ... | Sunday
  meal        String   // Breakfast | Lunch | Snacks | Dinner
  items       String   // pipe-separated items list
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")

  @@unique([blockId, day, meal])
  @@map("mess_menus")
}

model HostelComplaint {
  id           String    @id @default(uuid())
  studentId    String    @map("student_id")
  blockId      String?   @map("block_id")
  roomId       String?   @map("room_id")
  type         String    // maintenance | electrical | plumbing | housekeeping | noise | food | security | other
  title        String
  description  String
  priority     String    @default("medium")  // low | medium | high | urgent
  status       String    @default("open")    // open | in_progress | resolved | closed
  resolvedById String?   @map("resolved_by_id")
  resolvedAt   DateTime? @map("resolved_at")
  resolution   String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  student      User         @relation("StudentComplaints", fields: [studentId], references: [id])
  block        HostelBlock? @relation(fields: [blockId], references: [id])
  room         HostelRoom?  @relation(fields: [roomId], references: [id])
  resolvedBy   User?        @relation("WardenResolvedComplaints", fields: [resolvedById], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("hostel_complaints")
}

model HostelFee {
  id         String    @id @default(uuid())
  studentId  String    @map("student_id")
  amount     Float
  feeType    String    @default("hostel") @map("fee_type")  // hostel | mess | maintenance | security
  period     String    // e.g. "2025-26 Semester 1"
  dueDate    DateTime  @map("due_date")
  paidDate   DateTime? @map("paid_date")
  status     String    @default("pending")  // pending | paid | overdue | waived
  paymentRef String?   @map("payment_ref")
  remarks    String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  student    User @relation("StudentHostelFees", fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("hostel_fees")
}

// ─── Module: Events ──────────────────────────────────────────────

model Event {
  id                String      @id @default(uuid())
  title             String
  description       String
  venue             String
  eventDate         DateTime    @map("event_date")
  endDate           DateTime?   @map("end_date")
  category          String      @default("general")  // cultural | technical | sports | academic | workshop | seminar | general
  organizerType     String      @default("club")     // club | faculty | admin | department
  organizerName     String      @map("organizer_name")
  clubName          String?     @map("club_name")
  clubContact       String?     @map("club_contact")
  clubLogoBase64    String?     @map("club_logo_base64")
  facultyName       String?     @map("faculty_name")
  facultyPhone      String?     @map("faculty_phone")
  facultyEmail      String?     @map("faculty_email")
  registrationLink  String?     @map("registration_link")
  maxParticipants   Int?        @map("max_participants")
  tags              String      @default("")          // comma-separated tags
  isPublished       Boolean     @default(true)       @map("is_published")
  latitude          Float?       // map pin latitude
  longitude         Float?       // map pin longitude
  authorId          String      @map("author_id")
  createdAt         DateTime    @default(now())      @map("created_at")
  updatedAt         DateTime    @updatedAt           @map("updated_at")

  author            User        @relation("EventAuthor", fields: [authorId], references: [id])
  files             EventFile[]

  @@index([eventDate])
  @@index([authorId])
  @@index([category])
  @@map("events")
}

model EventFile {
  id            String   @id @default(uuid())
  eventId       String   @map("event_id")
  fileName      String   @map("file_name")
  fileBase64    String   @map("file_base64")
  fileType      String   @map("file_type")   // pdf | image | doc | ppt | other
  fileSizeKb    Int?     @map("file_size_kb")
  uploadedById  String   @map("uploaded_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploader      User     @relation("EventFileUploader", fields: [uploadedById], references: [id])

  @@index([eventId])
  @@map("event_files")
}

// ─── Lost & Found ─────────────────────────────────────────────────────────────

model LostFoundItem {
  id           String           @id @default(uuid())
  title        String
  description  String
  location     String           // where it was found
  foundDate    DateTime         @map("found_date")
  category     String           @default("other")  // electronics|bags|clothing|accessories|documents|keys|wallet|sports|other
  status       String           @default("found")  // found | claimed
  contactName  String           @map("contact_name")
  contactPhone String?          @map("contact_phone")
  contactEmail String?          @map("contact_email")
  images       LostFoundImage[]
  reportedById String           @map("reported_by_id")
  reportedBy   User             @relation("LostFoundReporter", fields: [reportedById], references: [id])
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@index([category])
  @@map("lost_found_items")
}

model LostFoundImage {
  id          String        @id @default(uuid())
  itemId      String        @map("item_id")
  imageBase64 String        @map("image_base64") // base64 encoded
  caption     String?                            // optional label
  createdAt   DateTime      @default(now()) @map("created_at")

  item        LostFoundItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("lost_found_images")
}

// ─── Module: Navigation Map Pins ─────────────────────────────────

model MapPin {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  category    String   @default("custom")  // custom | event-marker | poi
  latitude    Float
  longitude   Float
  icon        String   @default("📍")      // emoji icon
  color       String   @default("#C62828") // hex color
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  createdBy   User     @relation("MapPinCreator", fields: [createdById], references: [id])

  @@index([createdById])
  @@map("map_pins")
}

// ─── Module: Communities ─────────────────────────────────────────

model Community {
  id                   String   @id @default(uuid())
  name                 String   @unique
  description          String
  type                 String   @default("technical")  // technical | cultural | social | sports
  logoBase64           String?  @map("logo_base64")
  isRecruitmentActive  Boolean  @default(false) @map("is_recruitment_active")
  formUrl              String?  @map("form_url")
  memberCount          Int      @default(0) @map("member_count")
  foundedYear          Int?     @map("founded_year")
  tags                 String   @default("")  // comma-separated
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("communities")
}

// ─── Module: Assignments ─────────────────────────────────────────

model Assignment {
  id            String    @id @default(uuid())
  classroomId   String    @map("classroom_id")
  title         String
  description   String    @default("")
  pdfBase64     String?   @map("pdf_base64")
  pdfFileName   String?   @map("pdf_file_name")
  dueDate       DateTime? @map("due_date")
  createdById   String    @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  classroom     Classroom  @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  createdBy     User       @relation("AssignmentCreator", fields: [createdById], references: [id])
  submissions   AssignmentSubmission[]

  @@index([classroomId])
  @@map("assignments")
}

model AssignmentSubmission {
  id              String   @id @default(uuid())
  assignmentId    String   @map("assignment_id")
  studentId       String   @map("student_id")
  solutionBase64  String   @map("solution_base64")
  solutionFileName String  @map("solution_file_name")
  grade           String?  // A | B | C | D | F or numeric
  feedback        String?
  submittedAt     DateTime @default(now()) @map("submitted_at")

  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student         User       @relation("SubmissionStudent", fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@map("assignment_submissions")
}

// ─── Module: Management Directory ────────────────────────────────

model Management {
  id            String   @id @default(uuid())
  name          String
  designation   String   // Dean | HOD | Director etc.
  department    String?  // Computer Science, Mechanical, etc.
  school        String?  // School of Engineering, etc.
  office        String?  // 5th floor room 507
  phone         String?
  email         String?
  photoBase64   String?  @map("photo_base64")
  order         Int      @default(0)  // display ordering
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("management")
}

// ─── Module: Chat ────────────────────────────────────────────────

model ChatConversation {
  id            String            @id @default(uuid())
  createdAt     DateTime          @default(now()) @map("created_at")

  participants  ChatParticipant[]
  messages      ChatMessage[]

  @@map("chat_conversations")
}

model ChatParticipant {
  id              String           @id @default(uuid())
  conversationId  String           @map("conversation_id")
  userId          String           @map("user_id")
  joinedAt        DateTime         @default(now()) @map("joined_at")

  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User             @relation("UserChatParticipant", fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model ChatMessage {
  id              String           @id @default(uuid())
  conversationId  String           @map("conversation_id")
  senderId        String           @map("sender_id")
  content         String
  isRead          Boolean          @default(false) @map("is_read")
  sentAt          DateTime         @default(now()) @map("sent_at")

  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User             @relation("ChatMsgSender", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@map("chat_messages")
}

model BlockedUser {
  id         String   @id @default(uuid())
  blockerId  String   @map("blocker_id")
  blockedId  String   @map("blocked_id")
  createdAt  DateTime @default(now()) @map("created_at")

  blocker    User @relation("Blocker", fields: [blockerId], references: [id])
  blocked    User @relation("BlockedTarget", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
  @@map("blocked_users")
}
